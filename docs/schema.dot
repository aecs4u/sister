digraph ER {
  graph [
    rankdir=LR
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"
    fontsize=12
    splines=polyline
    nodesep=0.4
    ranksep=2.0
    bgcolor="#f0f4f8"
    pad=0.6
  ]
  node [shape=none margin=0 fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=9]
  edge [fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=8 color="#334155"]

  // ─────────────────────────────────────────────────────────────────────────
  // Shared normalised dimensions
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_shared {
    label="Shared normalised tables"
    style=rounded color="#0f766e" bgcolor="#ecfdf5"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#134e4a"
    margin=16

    cadastral_locations [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ccfbf1">
        <TR><TD COLSPAN="3" BGCOLOR="#0f766e" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_locations</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD> </TD><TD>cadastre_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>province</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>municipality</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>sheet</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>parcel</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>subunit</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>section</TD><TD>TEXT</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><I>UNQ(cadastre_type,province,municipality,sheet,parcel,subunit,section)</I></TD></TR>
      </TABLE>
    >]

    cadastral_subjects [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ccfbf1">
        <TR><TD COLSPAN="3" BGCOLOR="#0f766e" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_subjects</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD> </TD><TD>display_name</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>last_name</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>first_name</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>gender</TD><TD>TEXT(1)?</TD></TR>
        <TR><TD> </TD><TD>date_of_birth</TD><TD>TEXT?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_birth">birth_location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD> </TD><TD>birth_municipality_code</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>subject_type</TD><TD>TEXT?</TD></TR>
      </TABLE>
    >]

    ownership_rights [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ccfbf1">
        <TR><TD COLSPAN="3" BGCOLOR="#0f766e" ALIGN="CENTER"><FONT COLOR="white"><B>ownership_rights</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD> </TD><TD>right_type</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>right_code</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>right_description</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>ownership_share</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>start_date</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>end_date</TD><TD>TEXT?</TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // db_models.py — Visura Pipeline
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_visura {
    label="db_models.py — Visura Pipeline"
    style=rounded color="#3b82f6" bgcolor="#eff6ff"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#1e40af"
    margin=16

    visura_requests [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>visura_requests</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>request_id</B></TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>request_type</TD><TD>TEXT</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD>IDX</TD><TD>cache_key</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>cost_text</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>cost_value</TD><TD>REAL?</TD></TR>
        <TR><TD> </TD><TD>created_at</TD><TD>DATETIME</TD></TR>
      </TABLE>
    >]

    visura_responses [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>visura_responses</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="pk"><B>request_id</B></TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>success</TD><TD>BOOL</TD></TR>
        <TR><TD> </TD><TD>cadastre_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>data</TD><TD>JSON?</TD></TR>
        <TR><TD> </TD><TD>error</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>created_at</TD><TD>DATETIME</TD></TR>
      </TABLE>
    >]

    visura_properties [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>visura_properties</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD>id</TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>response_id</B></TD><TD>TEXT IDX</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_subject">subject_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD><B>DISC</B></TD><TD>property_type</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>address</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>partita</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>category</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>cadastral_class</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>consistency</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>income</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>census_zone</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>quality</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>area</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>dominical_income</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>agricultural_income</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>registered_office</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>province</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>municipality</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#1e40af"><I>property_type="building"|"land"|"entity"</I></FONT></TD></TR>
      </TABLE>
    >]

    visura_owners [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>visura_owners</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD>id</TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>response_id</B></TD><TD>TEXT IDX</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_subject">subject_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_right">right_id</TD><TD>INT IDX?</TD></TR>
      </TABLE>
    >]

    page_visits [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>page_visits</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD>id</TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>response_id</B></TD><TD>TEXT IDX</TD></TR>
        <TR><TD> </TD><TD>step</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>url</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>screenshot_url</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>form_elements_json</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>errors_json</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>timestamp</TD><TD>DATETIME?</TD></TR>
      </TABLE>
    >]

    visura_documents [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#dbeafe">
        <TR><TD COLSPAN="3" BGCOLOR="#1d4ed8" ALIGN="CENTER"><FONT COLOR="white"><B>visura_documents</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk">id</TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk"><B>response_id</B></TD><TD>TEXT IDX?</TD></TR>
        <TR><TD> </TD><TD>document_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>file_format</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>filename</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>file_path</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>file_size</TD><TD>INT?</TD></TR>
        <TR><TD> </TD><TD>subject</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>requested_at</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>created_at</TD><TD>DATETIME</TD></TR>
      </TABLE>
    >]

    document_metadata [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#bfdbfe">
        <TR><TD COLSPAN="3" BGCOLOR="#1e40af" ALIGN="CENTER"><FONT COLOR="white"><B>document_metadata</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="fk"><B>id</B></TD><TD>INT (→visura_documents)</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD> </TD><TD>municipality_code</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#1e40af"><I>— DatiRichiesta (parsed)</I></FONT></TD></TR>
        <TR><TD> </TD><TD>view_subtype</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>protocol</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>year</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#1e40af"><I>— TitoloVisura (parsed)</I></FONT></TD></TR>
        <TR><TD> </TD><TD>title</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>reference_date</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>registry_view_type</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>service_type</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>generation_date</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>generation_time</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>source_system</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#1e40af"><I>— DatiLiquidazione (parsed)</I></FONT></TD></TR>
        <TR><TD> </TD><TD>liquidation_protocol</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>liquidation_year</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>liquidation_units</TD><TD>INT?</TD></TR>
        <TR><TD> </TD><TD>requester</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#1e40af"><I>— StoriaImmobile.SuperficieF (parsed)</I></FONT></TD></TR>
        <TR><TD> </TD><TD>historical_total_area</TD><TD>DECIMAL?</TD></TR>
        <TR><TD> </TD><TD>historical_excluded_area</TD><TD>DECIMAL?</TD></TR>
        <TR><TD> </TD><TD>content</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><I>1:1 with visura_documents (XML/P7M only)</I></TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // db_models.py — Feedback
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_feedback {
    label="db_models.py — Feedback"
    style=rounded color="#ca8a04" bgcolor="#fefce8"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#854d0e"
    margin=16

    feedback_config [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fef9c3">
        <TR><TD COLSPAN="3" BGCOLOR="#a16207" ALIGN="CENTER"><FONT COLOR="white"><B>feedback_config</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD><B>id</B></TD><TD>INT (=1)</TD></TR>
        <TR><TD> </TD><TD>cc_emails</TD><TD>JSON</TD></TR>
        <TR><TD> </TD><TD>bcc_emails</TD><TD>JSON</TD></TR>
        <TR><TD> </TD><TD>invitation_subject</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_intro</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_bullets</TD><TD>JSON</TD></TR>
        <TR><TD> </TD><TD>invitation_cta_text</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_privacy_note</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_signature</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_unsub_text</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>invitation_unsub_link_text</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>grace_period_days</TD><TD>INT</TD></TR>
      </TABLE>
    >]

    feedback_unsubscribes [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fef9c3">
        <TR><TD COLSPAN="3" BGCOLOR="#a16207" ALIGN="CENTER"><FONT COLOR="white"><B>feedback_unsubscribes</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD><B>email</B></TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>unsubscribed_at</TD><TD>DATETIME TZ</TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // cadastral.py — Inspections
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_cadastral_inspections {
    label="cadastral.py — Inspections"
    style=rounded color="#dc2626" bgcolor="#fef2f2"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#7f1d1d"
    margin=16

    cadastral_inspections [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fee2e2">
        <TR><TD COLSPAN="3" BGCOLOR="#991b1b" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_inspections</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>entity</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>callback</TD><TD>BOOL</TD></TR>
        <TR><TD> </TD><TD>inspection_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>requester</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>document</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>outcome</TD><TD>TEXT</TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // cadastral.py — Query detail tables  (entity_type: "property" | "prospect")
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_query_details {
    label="cadastral.py — Entity query detail tables"
    style=rounded color="#ea580c" bgcolor="#fff7ed"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#7c2d12"
    margin=16

    cadastral_location_parameters [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fed7aa">
        <TR><TD COLSPAN="3" BGCOLOR="#9a3412" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_location_parameters</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_query"><B>query_id</B></TD><TD>TEXT IDX?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_insp"><B>inspection_id</B></TD><TD>TEXT IDX?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD> </TD><TD>property_id</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#7c2d12"><I>exactly one FK set per row</I></FONT></TD></TR>
      </TABLE>
    >]

    cadastral_property_properties [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fed7aa">
        <TR><TD COLSPAN="3" BGCOLOR="#9a3412" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_property_properties</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="fk"><B>id</B></TD><TD>TEXT</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="CENTER"><I>(stub)</I></TD></TR>
      </TABLE>
    >]

    cadastral_prospect_properties [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fed7aa">
        <TR><TD COLSPAN="3" BGCOLOR="#9a3412" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_prospect_properties</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="fk"><B>id</B></TD><TD>TEXT</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="CENTER"><I>(stub)</I></TD></TR>
      </TABLE>
    >]

    cadastral_prospect_owners [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#fed7aa">
        <TR><TD COLSPAN="3" BGCOLOR="#9a3412" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_prospect_owners</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="fk"><B>id</B></TD><TD>TEXT</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="CENTER"><I>(stub)</I></TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // cadastral.py — Queries + Legal Entity Search
  // (query_type: "entity_record" | "entity_search"; scope: "national" | "local")
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_les {
    label="cadastral.py — Queries + Legal Entity Search"
    style=rounded color="#7c3aed" bgcolor="#f5f3ff"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#4c1d95"
    margin=16

    cadastral_queries [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ede9fe">
        <TR><TD COLSPAN="3" BGCOLOR="#5b21b6" ALIGN="CENTER"><FONT COLOR="white"><B>cadastral_queries</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>TEXT?</TD></TR>
        <TR><TD><B>DISC</B></TD><TD>query_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>endpoint</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>status</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>timestamp</TD><TD>DATETIME</TD></TR>
        <TR><TD> </TD><TD>owner</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>query_datetime</TD><TD>DATETIME? (entity_record)</TD></TR>
        <TR><TD> </TD><TD>entity_type</TD><TD>TEXT? (property|prospect)</TD></TR>
        <TR><TD> </TD><TD>result</TD><TD>JSON? (entity_record)</TD></TR>
        <TR><TD> </TD><TD>source_timestamp</TD><TD>INT? (entity_record)</TD></TR>
        <TR><TD> </TD><TD>scope</TD><TD>TEXT? (entity_search)</TD></TR>
        <TR><TD> </TD><TD>callback</TD><TD>BOOL?</TD></TR>
        <TR><TD> </TD><TD>outcome</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#4c1d95"><I>query_type="entity_record" | "entity_search"</I></FONT></TD></TR>
      </TABLE>
    >]

    les_parameter [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ede9fe">
        <TR><TD COLSPAN="3" BGCOLOR="#5b21b6" ALIGN="CENTER"><FONT COLOR="white"><B>legal_entity_search_parameters</B></FONT></TD></TR>
        <TR><TD><B>PK/FK</B></TD><TD PORT="fk"><B>id</B></TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>tax_code</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>cadastre_type</TD><TD>TEXT</TD></TR>
        <TR><TD> </TD><TD>province</TD><TD>TEXT</TD></TR>
      </TABLE>
    >]

    les_entity [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#ede9fe">
        <TR><TD COLSPAN="3" BGCOLOR="#5b21b6" ALIGN="CENTER"><FONT COLOR="white"><B>legal_entity_search_entities</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>TEXT?</TD></TR>
