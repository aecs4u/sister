        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_unit">building_unit_id</TD><TD>INT?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_cs">current_state_id</TD><TD>INT?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
