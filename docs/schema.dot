        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>mutation_id</B></TD><TD>INT</TD></TR>
        <TR><TD> </TD><TD>owner_index</TD><TD>TEXT?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_subject">subject_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_right">right_id</TD><TD>INT IDX?</TD></TR>
      </TABLE>
    >]
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — db_models.py FK relations
  // ─────────────────────────────────────────────────────────────────────────
  visura_requests:pk -> visura_responses:pk [
    label="1:1" style=solid arrowhead=tee arrowtail=none color="#1d4ed8" penwidth=2
  ]
  visura_responses:pk -> visura_properties:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#1d4ed8" penwidth=1.5
  ]
  visura_responses:pk -> visura_owners:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#1d4ed8" penwidth=1.5
  ]
  visura_responses:pk -> page_visits:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#1d4ed8" penwidth=1.5
  ]
  visura_responses:pk -> visura_documents:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#1d4ed8" penwidth=1.5
  ]
  cadastral_locations:pk -> visura_requests:fk_loc [
    label="request location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  cadastral_locations:pk -> visura_properties:fk_loc [
    label="property location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  visura_documents:pk -> document_metadata:fk [
    label="1:1 (XML/P7M)" style=solid arrowhead=tee arrowtail=none color="#1d4ed8" penwidth=2
  ]
  cadastral_locations:pk -> document_metadata:fk_loc [
    label="doc location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  cadastral_subjects:pk -> visura_properties:fk_subject [
    label="entity subject" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  cadastral_subjects:pk -> visura_owners:fk_subject [
    label="owner subject" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  ownership_rights:pk -> visura_owners:fk_right [
    label="owner right" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — Entity query detail FK
  // ─────────────────────────────────────────────────────────────────────────
  cadastral_queries:pk -> cadastral_location_parameters:fk_query [
    label="1:1 (entity record)" style=solid arrowhead=tee arrowtail=none color="#9a3412" penwidth=2
  ]
  cadastral_queries:pk -> cadastral_property_properties:fk [
    label="1:1 (property)" style=solid arrowhead=tee arrowtail=none color="#9a3412" penwidth=2
  ]
  cadastral_queries:pk -> cadastral_prospect_properties:fk [
    label="1:1 (prospect)" style=solid arrowhead=tee arrowtail=none color="#9a3412" penwidth=2
  ]
  cadastral_queries:pk -> cadastral_prospect_owners:fk [
    label="1:N (prospect)" style=solid arrowhead=crow arrowtail=none color="#9a3412" penwidth=1.5
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — Inspections FK (cross-cluster to cadastral_location_parameters)
  // ─────────────────────────────────────────────────────────────────────────
  cadastral_inspections:pk -> cadastral_location_parameters:fk_insp [
    label="1:1" style=solid arrowhead=tee arrowtail=none color="#991b1b" penwidth=2
  ]
  cadastral_locations:pk -> cadastral_location_parameters:fk_loc [
    label="location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — Queries + Legal Entity Search FK
  // ─────────────────────────────────────────────────────────────────────────
  cadastral_queries:pk -> les_parameter:fk [
    label="1:1" style=solid arrowhead=tee arrowtail=none color="#5b21b6" penwidth=2
  ]
  cadastral_queries:pk -> les_entity:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#5b21b6" penwidth=1.5
  ]
  les_entity:pk -> les_geo_summary:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#5b21b6" penwidth=1.5
  ]
  les_entity:pk -> les_property:fk [
    label="1:N (local)" style=solid arrowhead=crow arrowtail=none color="#5b21b6" penwidth=1.5
  ]
  cadastral_subjects:pk -> les_entity:fk_subject [
    label="subject" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  cadastral_locations:pk -> les_property:fk_loc [
    label="location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — visura_documents → XML child tables (all anchor to visura_documents.pk)
  // ─────────────────────────────────────────────────────────────────────────
  visura_documents:pk -> document_subject:fk [
    label="1:1 (soggetto)" style=solid arrowhead=tee arrowtail=none color="#155e75" penwidth=2
  ]
  cadastral_subjects:pk -> document_subject:fk_subject [
    label="subject" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  visura_documents:pk -> property_group:fk [
    label="1:N (soggetto)" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]
  property_group:pk -> building_unit:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]
  visura_documents:pk -> building_current_state:fk [
    label="1:1 (storica)" style=solid arrowhead=tee arrowtail=none color="#155e75" penwidth=2
  ]
  visura_documents:pk -> building_address:fk [
    label="1:N (storica)" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]
  visura_documents:pk -> land_parcel:fk [
    label="1:N (terreni)" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]
  land_parcel:pk -> land_classification:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — XML polymorphic FKs (dashed = nullable)
  // ─────────────────────────────────────────────────────────────────────────
  building_unit:pk -> building_identifier:fk_unit [
    label="unit→id" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  building_current_state:fk -> building_identifier:fk_cs [
    label="cs→id" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  visura_documents:pk -> building_identifier:fk_doc [
    label="hist→id" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  cadastral_locations:pk -> building_identifier:fk_loc [
    label="location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]

  building_unit:pk -> building_classification:fk_unit [
    label="unit→class" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  building_current_state:fk -> building_classification:fk_cs [
    label="cs→class" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  visura_documents:pk -> building_classification:fk_doc [
    label="hist→class" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]

  building_unit:pk -> building_surface:fk_unit [
    label="unit→surf" style=dashed arrowhead=tee arrowtail=none color="#0891b2" penwidth=1.2
  ]
  building_current_state:fk -> building_surface:fk_cs [
    label="cs→surf" style=dashed arrowhead=tee arrowtail=none color="#0891b2" penwidth=1.2
  ]

  building_unit:pk -> related_parcel:fk_unit [
    label="unit→rel" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  building_current_state:fk -> related_parcel:fk_cs [
    label="cs→rel" style=dashed arrowhead=crow arrowtail=none color="#0891b2" penwidth=1.2
  ]
  cadastral_locations:pk -> related_parcel:fk_loc [
    label="location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  cadastral_locations:pk -> land_parcel:fk_loc [
    label="location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]

  // ─────────────────────────────────────────────────────────────────────────
  // Edges — XML ownership mutations (polymorphic)
  // ─────────────────────────────────────────────────────────────────────────
  visura_documents:pk -> ownership_mutation:fk_doc [
    label="storica" style=dashed arrowhead=crow arrowtail=none color="#0e7490" penwidth=1.5
  ]
  property_group:pk -> ownership_mutation:fk_grp [
    label="soggetto" style=dashed arrowhead=crow arrowtail=none color="#0e7490" penwidth=1.5
  ]
  land_parcel:pk -> ownership_mutation:fk_land [
    label="terreni" style=dashed arrowhead=crow arrowtail=none color="#0e7490" penwidth=1.5
  ]
  cadastral_locations:pk -> ownership_mutation:fk_ref_loc [
    label="ref location" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  ownership_mutation:pk -> property_owner:fk [
    label="1:N" style=solid arrowhead=crow arrowtail=none color="#155e75" penwidth=1.5
  ]
  cadastral_subjects:pk -> property_owner:fk_subject [
    label="owner subject" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
  ownership_rights:pk -> property_owner:fk_right [
    label="owner right" style=dashed arrowhead=crow arrowtail=none color="#0f766e" penwidth=1.2
  ]
}
