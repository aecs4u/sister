  // ─────────────────────────────────────────────────────────────────────────
  // visura_xml_models.py — Parsed XML child tables
  // ─────────────────────────────────────────────────────────────────────────
  subgraph cluster_xml {
    label="visura_xml_models.py — Parsed XML child tables  (all FK → visura_documents.id)"
    style=rounded color="#0891b2" bgcolor="#ecfeff"
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif" fontsize=12 fontcolor="#164e63"
    margin=16

    document_subject [label=<
