    land_parcel [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#cffafe">
        <TR><TD COLSPAN="3" BGCOLOR="#155e75" ALIGN="CENTER"><FONT COLOR="white"><B>land_parcels</B></FONT></TD></TR>
        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>document_id</B></TD><TD>INT</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_loc">location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD> </TD><TD>municipality_code</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>sequence_id</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>partita</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><I>terreni_attuale only</I></TD></TR>
      </TABLE>
    >]

    land_classification [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3" BGCOLOR="#cffafe">
        <TR><TD COLSPAN="3" BGCOLOR="#155e75" ALIGN="CENTER"><FONT COLOR="white"><B>land_classifications</B></FONT></TD></TR>
