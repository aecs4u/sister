        <TR><TD><B>FK?</B></TD><TD PORT="fk_grp">property_group_id</TD><TD>INT?</TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_land">land_parcel_id</TD><TD>INT?</TD></TR>
        <TR><TD> </TD><TD>mutation_index</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>mutation_date</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>source_description</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><FONT COLOR="#164e63"><I>— ref cross-reference</I></FONT></TD></TR>
        <TR><TD><B>FK?</B></TD><TD PORT="fk_ref_loc">reference_location_id</TD><TD>INT IDX?</TD></TR>
        <TR><TD> </TD><TD>ref_municipality_code</TD><TD>TEXT?</TD></TR>
