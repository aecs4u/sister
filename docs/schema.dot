        <TR><TD><B>PK</B></TD><TD PORT="pk"><B>id</B></TD><TD>INT AI</TD></TR>
        <TR><TD><B>FK</B></TD><TD PORT="fk"><B>document_id</B></TD><TD>INT</TD></TR>
        <TR><TD> </TD><TD>address_text</TD><TD>TEXT?</TD></TR>
        <TR><TD> </TD><TD>situation</TD><TD>TEXT?</TD></TR>
        <TR><TD COLSPAN="3" ALIGN="LEFT"><I>StoriaImmobileFabbricati history rows</I></TD></TR>
