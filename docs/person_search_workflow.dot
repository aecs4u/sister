// SISTER — "Person Search" (Persona Fisica) workflow
// Render: dot -Tsvg person_search_workflow.dot -o person_search_workflow.svg
digraph PersonSearch {
  rankdir=TB;
  fontname="Helvetica"; fontsize=12;
  labelloc="t";
  label="SISTER — \"Person Search\" (Persona Fisica) workflow\nRule: at every table, repeat the request for EACH row, unless that row's data is already extracted";
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9];

  // ---- legend ----
  subgraph cluster_legend {
    label="Legend"; style="dashed"; color="gray60"; fontsize=10;
    lg_page  [shape=box,       style="rounded,filled", fillcolor="#E8F0FE", label="page / form"];
    lg_act   [shape=box,       style="filled",         fillcolor="#FFF4E5", label="button / action"];
    lg_tab   [shape=box,       style="filled",         fillcolor="#FDE7E9", label="TABLE (iterate rows)"];
    lg_dec   [shape=diamond,   style="filled",         fillcolor="#FFFDE7", label="decision / loop"];
    lg_data  [shape=note,      style="filled",         fillcolor="#E6F4EA", label="artifact / data"];
    lg_cost  [shape=box,       style="rounded,filled", fillcolor="#F3E5F5", label="BILLABLE + CAPTCHA"];
    lg_wait  [shape=hexagon,   style="filled",         fillcolor="#FFCC80", label="WAIT for user input\n(manual / human-in-the-loop)"];
    lg_page -> lg_act -> lg_tab -> lg_dec -> lg_data -> lg_cost -> lg_wait [style=invis];
  }

  // ---- auth ----
  start  [shape=ellipse, style=filled, fillcolor="#D2E3FC", label="Authenticated SISTER session\n(manual CIE/SPID via iampe login)"];

  // ---- entry ----
  scelta [shape=box, style="rounded,filled", fillcolor="#E8F0FE",
          label="SceltaServizio.do\nselect Provincia / NAZIONALE\n(select[name=listacom]) → [Applica]"];
  pf     [shape=box, style="filled", fillcolor="#FFF4E5", label="click left-menu link\n\"Persona fisica\""];
  form   [shape=box, style="rounded,filled", fillcolor="#E8F0FE",
          label="DataRichiesta.do — Ricerca persona fisica\n1) check CF radio  input[name=selDatiAna][value=CF_PF]\n2) fill  input[name=cod_fisc_pf]\n3) [Ricerca]"];

  // ---- omonimi table ----
  omon   [shape=box, style="filled", fillcolor="#FDE7E9",
          label="RicercaPF.do — TABLE \"Elenco Omonimi\"\nCognome | Nome | Nascita | Luogo | Sesso | CF"];
  omon_loop [shape=diamond, style="filled", fillcolor="#FFFDE7",
          label="for each omonimo\n(unless extracted)"];
  omon_pick [shape=box, style="filled", fillcolor="#FFF4E5", label="select row radio → [Ricerca]"];

  // ---- province table ----
  prov   [shape=box, style="filled", fillcolor="#FDE7E9",
          label="SceltaOmonimiPF.do — TABLE \"Elenco Province\"\nProvincia | Fabbricati | Terreni | Comuni"];
  prov_loop [shape=diamond, style="filled", fillcolor="#FFFDE7",
          label="for each provincia\n(unless extracted)"];
  prov_pick [shape=box, style="filled", fillcolor="#FFF4E5", label="select row radio → [Immobili]"];

  // ---- immobili table ----
  imm    [shape=box, style="filled", fillcolor="#FDE7E9",
          label="SceltaVisuraNazionalePF.do — TABLE \"Elenco immobili\"\nCatasto | Titolarità | Ubicazione | Foglio | Part. | Sub | Classamento | Rendita …"];
  imm_loop [shape=diamond, style="filled", fillcolor="#FFFDE7",
          label="for each immobile\n(unless extracted)"];
  imm_pick [shape=box, style="filled", fillcolor="#FFF4E5", label="select row radio"];
  imm_branch [shape=diamond, style="filled", fillcolor="#FFFDE7", label="which output?"];

  // ---- branch A: visura per immobile ----
  optV   [shape=box, style="rounded,filled", fillcolor="#F3E5F5",
          label="SceltaVisuraImmSoggPF.do — \"Tipo di visura\"\nset options: intestati(1/0) · tipoVisura(Completa/Storica) · tipoDocFornitura(PDF/XML)"];

  // ---- branch B: intestati table ----
  intes  [shape=box, style="filled", fillcolor="#FDE7E9",
          label="TABLE \"Elenco Intestati\"\nNominativo | Codice fiscale | Titolarità | Quota"];
  intes_loop [shape=diamond, style="filled", fillcolor="#FFFDE7",
          label="for each intestato\n(unless extracted)"];
  intes_pick [shape=box, style="filled", fillcolor="#FFF4E5", label="select row radio → [Visura per Soggetto]"];
  optS   [shape=box, style="rounded,filled", fillcolor="#F3E5F5",
          label="SceltaIntestatiPF.do / TipoVisura.do — \"Visura soggetto\"\nset options: intestati · Sintetica/Analitica · PDF/XML"];

  // ---- shared CAPTCHA handling (human-in-the-loop) ----
  cap_req  [shape=diamond, style="filled", fillcolor="#FFFDE7", label="CAPTCHA\nrequired?"];
  cap_wait [shape=hexagon, style="filled", fillcolor="#FFCC80",
            label="WAIT for user to enter\n\"Codice di sicurezza\"\n(input[name=inCaptchaChars])\n— pause until provided —"];
  inoltra  [shape=box, style="filled", fillcolor="#FFF4E5", label="[Inoltra]"];
  cap_ok   [shape=diamond, style="filled", fillcolor="#FFFDE7", label="CAPTCHA\naccepted?"];

  // ---- document ready + download + extract ----
  ready  [shape=box, style="rounded,filled", fillcolor="#E8F0FE",
          label="CheckRichiesta — \"Documento pronto\"\n(also kept 1 week under \"Richieste\")"];
  salva  [shape=box, style="filled", fillcolor="#FFF4E5",
          label="[Salva]  → download from\nConsultazioneRichieste.do"];
  p7m    [shape=note, style="filled", fillcolor="#E6F4EA",
          label="DOC_<idRichiesta>.p7m\nDER PKCS#7 Signed Data (CAdES)\npayload = signed XML (Visure_SIT_ver1.0.xsd)"];
  xml    [shape=note, style="filled", fillcolor="#E6F4EA",
          label="extract XML:\nopenssl cms -verify -noverify -inform DER\n→ <Visura> (Fabbricato | Soggetto)"];

  // ---- back navigation ----
  back   [shape=box, style="filled", fillcolor="#ECEFF1",
          label="[Indietro]\nstep one level up the flow"];

  // ---- edges ----
  start -> scelta -> pf -> form -> omon;

  omon -> omon_loop;
  omon_loop -> omon_pick [label="next row"];
  omon_pick -> prov;
  prov -> prov_loop;
  prov_loop -> prov_pick [label="next row"];
  prov_pick -> imm;
  imm -> imm_loop;
  imm_loop -> imm_pick [label="next row"];
  imm_pick -> imm_branch;

  imm_branch -> optV   [label="Visura Per Immobile"];
  imm_branch -> intes  [label="Intestati"];

  // branch B drilldown to soggetto option page
  intes -> intes_loop;
  intes_loop -> intes_pick [label="next row"];
  intes_pick -> optS;

  // shared CAPTCHA handling — both option pages converge here
  optV -> cap_req;
  optS -> cap_req;
  cap_req -> cap_wait  [label="yes"];
  cap_req -> inoltra   [label="no"];
  cap_wait -> inoltra  [label="user submitted code"];
  inoltra -> cap_ok;
  cap_ok -> ready      [label="yes"];
  cap_ok -> cap_wait   [label="no — new image,\nwait again", color="#C62828", fontcolor="#C62828"];

  // document path
  ready -> salva -> p7m -> xml;

  // back navigation (dashed)
  edge [style=dashed, color="gray50"];
  imm   -> prov   [label="Indietro", constraint=false];
  prov  -> omon   [label="Indietro", constraint=false];
  intes -> imm    [label="Immobili / Indietro", constraint=false];
  ready -> imm    [label="Indietro", constraint=false];
  xml   -> imm_loop [label="loop: next immobile\n(unless extracted)", constraint=false];
}
