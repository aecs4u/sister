# Variabili d'ambiente per il servizio Visura API
# Copia questo file in .env e inserisci le tue credenziali:
#   cp .env.example .env

# === Credenziali SPID / Agenzia delle Entrate ===
ADE_USERNAME=il_tuo_codice_fiscale
ADE_PASSWORD=la_tua_password

# === Autenticazione (opzionale, gestite da aecs4u-auth) ===
# ADE_AUTH_METHOD=spid              # spid | cie | cns | fisconline
# ADE_SPID_PROVIDER=sielte          # sielte | aruba | poste | namirial
# ADE_OTP_SECRET=                   # Secret TOTP base32 (per provider con OTP)
# BROWSER_MFA_TIMEOUT=120           # Timeout in secondi per approvazione MFA
# BROWSER_HEADLESS=true             # Esegui browser in modalità headless

# === Configurazione opzionale ===

# Livello di log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Protegge POST /shutdown via header X-API-Key
# SHUTDOWN_API_KEY=una_chiave_lunga

# Cache risultati
# RESPONSE_TTL_SECONDS=21600        # Default 6 ore
# RESPONSE_MAX_ITEMS=5000           # Massimo risultati in memoria

# Non modificare queste (necessarie per Playwright in Docker)
PYTHONUNBUFFERED=1
DISPLAY=:99
